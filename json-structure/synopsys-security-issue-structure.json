{
  "name": "Security Issue",
  "description": "Synopsys Polaris security issue structure.",
  "fields": [
    { "name": "id", "type": "string", "required": true },
    { "name": "type", "type": "enum", "required": true, "values": ["sast", "sca", "iast"] },
    { "name": "severity", "type": "enum", "required": true, "values": ["critical", "high", "medium", "low"] },
    { "name": "name", "type": "string", "required": true },
    { "name": "description", "type": "string", "required": false },
    { "name": "cwe", "type": "string", "required": false },
    { "name": "cve", "type": "string", "required": false },
    { "name": "filePath", "type": "string", "required": false },
    { "name": "lineNumber", "type": "integer", "required": false },
    { "name": "status", "type": "enum", "required": true, "values": ["open", "dismissed", "fixed"] },
    { "name": "projectId", "type": "string", "required": false },
    { "name": "branchId", "type": "string", "required": false }
  ]
}
