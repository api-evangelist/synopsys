{
  "opencollection": "1.0.0",
  "info": {
    "name": "Synopsys Cloud OpenLink API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "X-API-Key",
      "value": "{{X-API-Key}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Entitlements",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Vendor Entitlements",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.synopsys.com/openlink/v1/entitlements",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Called by Synopsys Cloud to retrieve available licenses for a specific customer. This endpoint is registered by the vendor during onboarding. Returns an array of entitlements with associated license details."
        }
      ]
    },
    {
      "info": {
        "name": "Licenses",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Generate License File",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.synopsys.com/openlink/v1/licenses",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Called by Synopsys Cloud to generate and retrieve a license file for a customer. This endpoint is dynamically provided via the entitlement response. Supports synchronous delivery (within 20 seconds) and asynchronous delivery with polling."
        },
        {
          "info": {
            "name": "Download License File",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.synopsys.com/openlink/v1/licenses/:licenseId",
            "params": [
              {
                "name": "licenseId",
                "value": "",
                "type": "path",
                "description": "License file identifier."
              }
            ]
          },
          "docs": "Retrieves a previously generated license file by its identifier. Used for asynchronous license polling scenarios."
        }
      ]
    }
  ],
  "bundled": true
}